{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://kyriux.duckdns.org:3000/api/v1",
        "EXPO_PUBLIC_APP_NAME": "BBVA Dashboard"
      }
    },
    "production": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://kyriux.duckdns.org:3000/api/v1",
        "EXPO_PUBLIC_APP_NAME": "BBVA Dashboard"
      }
    }
  }
}